FRONTEND_URL=http://localhost:3000

# Supabase Postgres direct connection used by Prisma and database access
DATABASE_URL=
PRISMA_DATABASE_URL=
PRISMA_DIRECT_URL=
SUPABASE_POSTGRES_DIRECT_URL=
SUPABASE_SYNC_DATABASE_URL=

# Google OAuth client credentials from Google Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Backend session settings
SESSION_JWT_SECRET=
SESSION_COOKIE_NAME=cc_session
SESSION_TTL_MINUTES=480

# Twilio SMS provider
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional infra settings
ENABLE_INFRA_ON_STARTUP=false


